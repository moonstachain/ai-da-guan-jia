{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "tasks",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "task_id",
      "title",
      "status",
      "source_ref",
      "confidence",
      "updated_at"
    ],
    "properties": {
      "id": { "type": "string" },
      "task_id": { "type": "string" },
      "title": { "type": "string" },
      "goal_id": { "type": "string" },
      "thread_id": { "type": "string" },
      "status": { "type": "string" },
      "priority": { "type": "string" },
      "priority_band": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] },
      "owner_mode": { "type": "string" },
      "component_domain": { "type": "string" },
      "control_level": { "type": "string", "enum": ["direct", "control", "execute"] },
      "task_kind": { "type": "string" },
      "parent_task_id": { "type": "string" },
      "depends_on_task_ids": { "type": "array", "items": { "type": "string" } },
      "managed_by": { "type": "string" },
      "intake_run_id": { "type": "string" },
      "delegation_mode": { "type": "string" },
      "human_boundary_state": { "type": "string" },
      "osa_card_ref": { "type": "string" },
      "handoff_ref": { "type": "string" },
      "selected_skills": { "type": "array", "items": { "type": "string" } },
      "verification_state": { "type": "string" },
      "verification_target": { "type": "array", "items": { "type": "string" } },
      "interrupt_only_if": { "type": "string" },
      "evidence_ref": { "type": "string" },
      "evidence_strength": { "type": "string" },
      "execution_mode": { "type": "string" },
      "runner_state": { "type": "string" },
      "run_artifact_ref": { "type": "string" },
      "result_summary": { "type": "string" },
      "evidence_refs": { "type": "array", "items": { "type": "string" } },
      "kpi_gap": { "type": "string" },
      "closure_state": { "type": "string" },
      "closure_run_id": { "type": "string" },
      "blocker_reason": { "type": "string" },
      "required_human_input": { "type": "string" },
      "next_action": { "type": "string" },
      "source_ref": { "type": "string" },
      "confidence": { "type": "number" },
      "last_updated_at": { "type": "string" },
      "updated_at": { "type": "string" }
    },
    "additionalProperties": true
  }
}
