    "source_scope",
    "counts",
    "spaces",
    "subjects",
    "endpoints",
    "accounts",
    "operating_modules",
    "source_feeds",
    "ingestion_runs",
    "assets",
    "orders",
    "cashflows",
    "tasks",
    "threads",
    "skills",
    "review_runs",
    "relations"
  ],
  "properties": {
    "generated_at": { "type": "string" },
    "source_scope": { "type": "object" },
    "counts": { "type": "object" },
    "ontology_summary": { "type": "object" },
    "spaces": { "$ref": "spaces.schema.json" },
    "subjects": { "$ref": "subjects.schema.json" },
    "endpoints": { "$ref": "endpoints.schema.json" },
    "accounts": { "$ref": "accounts.schema.json" },
    "operating_modules": { "$ref": "operating_modules.schema.json" },
    "source_feeds": { "$ref": "source_feeds.schema.json" },
    "ingestion_runs": { "$ref": "ingestion_runs.schema.json" },
    "assets": { "$ref": "assets.schema.json" },
    "orders": { "$ref": "orders.schema.json" },
    "cashflows": { "$ref": "cashflows.schema.json" },
    "tasks": { "$ref": "tasks.schema.json" },
    "threads": { "$ref": "threads.schema.json" },
    "skills": { "$ref": "skills.schema.json" },
    "review_runs": { "$ref": "review_runs.schema.json" },
    "relations": { "$ref": "relations.schema.json" }
  },
  "additionalProperties": true
