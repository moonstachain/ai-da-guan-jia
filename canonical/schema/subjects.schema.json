{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "subjects",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "subject_id",
      "title",
      "subject_type",
      "space_id",
      "status",
      "source_ref",
      "confidence",
      "updated_at"
    ],
    "properties": {
      "id": { "type": "string" },
      "subject_id": { "type": "string" },
      "title": { "type": "string" },
      "subject_type": { "type": "string" },
      "space_id": { "type": "string" },
      "autonomy_tier": { "type": "string" },
      "responsibility_scope": { "type": "array", "items": { "type": "string" } },
      "status": { "type": "string" },
      "owner_mode": { "type": "string" },
      "source_ref": { "type": "string" },
      "confidence": { "type": "number" },
      "updated_at": { "type": "string" }
    },
    "additionalProperties": true
  }
}
