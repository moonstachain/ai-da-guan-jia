{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "threads",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "thread_id",
      "title",
      "status",
      "source_ref",
      "confidence",
      "updated_at"
    ],
    "properties": {
      "id": { "type": "string" },
      "thread_id": { "type": "string" },
      "title": { "type": "string" },
      "theme": { "type": "string" },
      "goal_id": { "type": "string" },
      "strategy_id": { "type": "string" },
      "experiment_id": { "type": "string" },
      "workflow_id": { "type": "string" },
      "component_domain": { "type": "string" },
      "control_level": { "type": "string", "enum": ["direct", "control", "execute"] },
      "priority_band": { "type": "string", "enum": ["P0", "P1", "P2", "P3"] },
      "evidence_strength": { "type": "string" },
      "status": { "type": "string" },
      "source_run_id": { "type": "string" },
      "entry_mode": { "type": "string" },
      "parent_task_id": { "type": "string" },
      "managed_by": { "type": "string" },
      "osa_card_ref": { "type": "string" },
      "orchestration_state": { "type": "string" },
      "closure_state": { "type": "string" },
      "closure_run_id": { "type": "string" },
      "blocker_reason": { "type": "string" },
      "required_human_input": { "type": "string" },
      "open_questions": { "type": "array", "items": { "type": "string" } },
      "morning_review_flag": { "type": "boolean" },
      "next_review_date": { "type": "string" },
      "source_ref": { "type": "string" },
      "confidence": { "type": "number" },
      "updated_at": { "type": "string" }
    },
    "additionalProperties": true
  }
}
