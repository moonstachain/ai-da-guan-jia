# Research-only RD-Agent template for the fin_quant scenario.
# Fill in provider credentials in a private copy before uploading to the host.

PYTHONPATH=./
RDAGENT_SETTINGS_MODULE=rdagent.app.qlib_rd_loop_conf
SCEN=fin_quant

# External LLM backend.
MODEL_BACKEND=openai
CHAT_MODEL=gpt-4.1-mini
OPENAI_API_KEY=
OPENAI_API_BASE=
EMBEDDING_MODEL=text-embedding-3-small

# Keep RD-Agent session state on disk for reproducibility.
SESSION_USE_FILE_STORAGE=true

# fin_quant relies on a Docker-backed execution environment in official docs.
MODEL_COSTEER_ENV_TYPE=docker

# Local working directories inside the deployed repo.
WORKING_DIR=./state/work_dir
RDAGENT_LOG_DIR=./logs

# Factor/model template settings from the official .env.example.
TGT_TPL_V02_QLIB_FACTOR_IMPLEMENT_SETTINGS_PATH=./git_ignore_folder/setting/factor_implementation_template.yaml
TGT_TPL_V02_QLIB_MODEL_IMPLEMENT_SETTINGS_PATH=./git_ignore_folder/setting/model_implementation_template.yaml

# Optional Qlib override. The bundle prepares CN data in this path by default.
QLIB_PROVIDER_URI=~/.qlib/qlib_data/cn_data

# Leave unset unless you have a confirmed Docker image and execution contract.
# DEFAULT_EXECUTION_ENV={"docker_image":"local_kgym","conda":"rdagent"}
