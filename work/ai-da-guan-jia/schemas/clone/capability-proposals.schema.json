{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Capability Proposals",
  "description": "clone 向母体提交的方法晋升提案",
  "type": "object",
  "required": ["proposals"],
  "properties": {
    "proposals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["proposal_id", "clone_id", "timestamp", "type", "title", "description", "status"],
        "properties": {
          "proposal_id": { "type": "string", "pattern": "^CP-[0-9]+$" },
          "clone_id": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "type": { "type": "string", "enum": ["skill_improvement", "workflow_new", "rule_change", "template_update"] },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "evidence": { "type": "string" },
          "status": { "type": "string", "enum": ["pending_review", "approved", "rejected", "promoted", "deferred"] },
          "mother_verdict": { "type": ["string", "null"] },
          "mother_reviewer": { "type": ["string", "null"], "description": "claude / human / both" },
          "promoted_to": { "type": ["string", "null"], "description": "shared core 的目标位置" },
          "reviewed_at": { "type": ["string", "null"], "format": "date-time" }
        }
      }
    }
  }
}
