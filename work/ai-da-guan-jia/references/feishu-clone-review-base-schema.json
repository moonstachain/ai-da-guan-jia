        "Source Run ID",
        "Evidence Ref",
        "Updated At"
      ],
      "views": ["全部", "待总部复核", "共享核心候选"]
    },
    {
      "table_name": "实例评分表",
      "primary_field": "Clone Score Key",
      "fields": [
        "Report ID",
        "Clone ID",
        "显示名",
        "Customer ID",
        "Org ID",
        "Tenant ID",
        "Actor Type",
        "Role Template ID",
        "Portfolio",
        "Clone Mode",
        "Training Runs",
        "Task Success Rate",
        "Verification Strength",
        "Distortion Rate",
