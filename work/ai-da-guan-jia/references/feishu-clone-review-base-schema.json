        "Promotion Recommendation",
        "Budget Weight",
        "Last Run ID",
        "Updated At"
      ],
      "views": ["全部", "高优先级", "晋升候选"]
    },
    {
      "table_name": "风险与决策表",
      "primary_field": "Alert Key",
      "fields": [
        "Report ID",
        "Clone ID",
        "显示名",
        "Org ID",
        "Tenant ID",
        "Portfolio",
        "Alert Type",
        "Severity",
        "Title",
        "Recommended Action",
        "Approval Required",
        "Status",
        "Evidence Ref",
        "Updated At"
      ],
      "views": ["全部", "待你拍板", "风险告警"]
    }
  ]
