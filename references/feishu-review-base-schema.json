{
  "base_name": "技能盘点",
  "tables": [
    {
      "table_name": "复盘批次",
      "primary_field": "Review ID",
      "fields": [
        "日期",
        "创建时间",
        "状态",
        "本地技能数",
        "GitHub来源数",
        "层级分布",
        "总评摘要",
        "最强区块",
        "最弱区块",
        "中层缺口",
        "推荐动作",
        "已选动作",
        "resolved_at",
        "review.md路径",
        "review.json路径"
      ],
      "views": ["全部"]
    },
    {
      "table_name": "技能清单快照",
      "primary_field": "Snapshot ID",
      "fields": [
        "Review ID",
        "Skill 名",
        "主层级",
        "簇",
        "类型",
        "资源完整度",
        "有无 scripts",
        "有无 references",
        "GitHub来源",
        "来源类型",
        "顺手度判断",
        "边界备注"
      ],
      "views": ["全部"]
    },
    {
      "table_name": "候选进化动作",
      "primary_field": "Action Key",
      "fields": [
        "Review ID",
        "动作ID",
        "动作类型",
        "标题",
        "问题",
        "建议改动",
        "预期收益",
        "风险",
        "下一步建议",
        "是否被选中",
        "是否已完成"
      ],
      "views": ["全部"]
    },
    {
      "table_name": "关键发现",
      "primary_field": "Finding ID",
      "fields": [
        "Review ID",
        "发现类型",
        "标题",
        "对象1",
        "对象2",
        "结论",
        "建议规则"
      ],
      "views": ["全部"]
    },
    {
      "table_name": "GitHub来源",
      "primary_field": "Source Key",
      "fields": [
        "Review ID",
        "仓库",
        "证据类型",
        "本地映射 skill 数",
        "代表 skill",
        "评价",
        "是否建议反向沉淀"
      ],
      "views": ["全部"]
    }
  ]
}
