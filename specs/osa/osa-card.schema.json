{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "osa-card",
  "type": "object",
  "required": [
    "schema_version",
    "osa_id",
    "generated_at",
    "task_context",
    "governance_judgments",
    "objective",
    "strategy",
    "action",
    "closure_gate",
    "interface_projection"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "osa_id": { "type": "string" },
    "generated_at": { "type": "string" },
    "task_context": {
      "type": "object",
      "required": [
        "task_id",
        "title",
        "goal_id",
        "space_id",
        "target_module_id",
        "status",
        "source_ref"
      ],
      "properties": {
        "task_id": { "type": "string" },
        "title": { "type": "string" },
        "goal_id": { "type": "string" },
        "space_id": { "type": "string" },
        "target_module_id": { "type": "string" },
        "status": { "type": "string" },
        "source_ref": { "type": "string" }
      },
      "additionalProperties": true
    },
    "governance_judgments": {
      "type": "object",
      "required": [
        "autonomy_judgment",
        "global_optimum_judgment",
        "capability_reuse_judgment",
        "verification_judgment",
        "evolution_judgment",
        "current_max_distortion"
      ],
      "properties": {
        "autonomy_judgment": { "$ref": "#/$defs/decisionWithBasis" },
        "global_optimum_judgment": { "$ref": "#/$defs/decisionWithBasis" },
        "capability_reuse_judgment": { "$ref": "#/$defs/decisionWithBasis" },
        "verification_judgment": { "$ref": "#/$defs/decisionWithBasis" },
        "evolution_judgment": { "$ref": "#/$defs/decisionWithBasis" },
        "current_max_distortion": {
          "type": "object",
          "required": ["distortion", "why_it_matters"],
          "properties": {
            "distortion": { "type": "string" },
            "why_it_matters": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "objective": {
      "type": "object",
      "required": [
        "origin_goal_alignment",
        "strategic_goal_alignment",
        "task_goal_definition",
        "distortion_boundary"
      ],
      "properties": {
        "origin_goal_alignment": {
          "type": "object",
          "required": ["charter_relation", "recursive_value"],
          "properties": {
            "charter_relation": { "type": "string" },
            "recursive_value": { "type": "string" }
          },
          "additionalProperties": true
        },
        "strategic_goal_alignment": {
          "type": "object",
          "required": ["goal_id", "strategic_goal", "relation"],
          "properties": {
            "goal_id": { "type": "string" },
            "strategic_goal": { "type": "string" },
            "relation": { "type": "string" }
          },
          "additionalProperties": true
        },
        "task_goal_definition": {
          "type": "object",
          "required": ["deliverable", "done_definition", "not_in_scope"],
          "properties": {
            "deliverable": { "type": "string" },
            "done_definition": { "type": "array", "items": { "type": "string" } },
            "not_in_scope": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": true
        },
        "distortion_boundary": {
          "type": "object",
          "required": ["pseudo_completion_risk", "prevention_rule"],
          "properties": {
            "pseudo_completion_risk": { "type": "string" },
            "prevention_rule": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "strategy": {
      "type": "object",
      "required": [
        "external_benchmarking",
        "prior_experience",
        "feasibility_assessment",
        "path_decision",
        "verification_target"
      ],
      "properties": {
        "external_benchmarking": { "type": "array", "items": { "type": "string" } },
        "prior_experience": { "type": "array", "items": { "type": "string" } },
        "feasibility_assessment": {
          "type": "object",
          "required": ["cost_level", "dependencies", "risks", "verification_difficulty"],
          "properties": {
            "cost_level": { "type": "string" },
            "dependencies": { "type": "array", "items": { "type": "string" } },
            "risks": { "type": "array", "items": { "type": "string" } },
            "verification_difficulty": { "type": "string" }
          },
          "additionalProperties": true
        },
        "path_decision": {
          "type": "object",
          "required": ["chosen_path", "rejected_alternatives", "rationale"],
          "properties": {
            "chosen_path": { "type": "string" },
            "rejected_alternatives": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["path", "reason"],
                "properties": {
                  "path": { "type": "string" },
                  "reason": { "type": "string" }
                },
                "additionalProperties": true
              }
            },
            "rationale": { "type": "string" }
          },
          "additionalProperties": true
        },
        "verification_target": {
          "type": "object",
          "required": ["evidence_required", "pass_condition"],
          "properties": {
            "evidence_required": { "type": "array", "items": { "type": "string" } },
            "pass_condition": { "type": "string" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "action": {
      "type": "object",
      "required": [
        "work_breakdown",
        "capability_orchestration",
        "control_gates",
        "human_boundary",
        "closure_outputs"
      ],
      "properties": {
        "work_breakdown": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["step_id", "description", "depends_on"],
            "properties": {
              "step_id": { "type": "string" },
              "description": { "type": "string" },
              "depends_on": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": true
          }
        },
        "capability_orchestration": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["step_id", "primary_executor", "selected_tools", "reason"],
            "properties": {
              "step_id": { "type": "string" },
              "primary_executor": { "type": "string" },
              "selected_tools": { "type": "array", "items": { "type": "string" } },
              "reason": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "control_gates": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["gate", "trigger", "check", "escalation_condition"],
            "properties": {
              "gate": { "type": "string" },
              "trigger": { "type": "string" },
              "check": { "type": "string" },
              "escalation_condition": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "human_boundary": {
          "type": "object",
          "required": ["default_mode", "escalate_only_when"],
          "properties": {
            "default_mode": { "type": "string" },
            "escalate_only_when": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": true
        },
        "closure_outputs": {
          "type": "object",
          "required": ["final_result", "evidence", "retrospective", "next_iteration_candidates"],
          "properties": {
            "final_result": { "type": "string" },
            "evidence": { "type": "array", "items": { "type": "string" } },
            "retrospective": { "type": "array", "items": { "type": "string" } },
            "next_iteration_candidates": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "closure_gate": {
      "type": "object",
      "required": [
        "result_status",
        "evidence",
        "gain",
        "waste",
        "next_iterate",
        "rule_candidate"
      ],
      "properties": {
        "result_status": { "type": "string" },
        "evidence": { "type": "array", "items": { "type": "string" } },
        "gain": { "type": "array", "items": { "type": "string" } },
        "waste": { "type": "array", "items": { "type": "string" } },
        "next_iterate": { "type": "array", "items": { "type": "string" } },
        "rule_candidate": { "type": "string" }
      },
      "additionalProperties": true
    },
    "interface_projection": {
      "type": "object",
      "required": ["route", "strategy_governor", "review_close_task"],
      "properties": {
        "route": {
          "type": "object",
          "required": ["recommended_skill_chain", "verification_target", "control_gates"],
          "properties": {
            "recommended_skill_chain": { "type": "array", "items": { "type": "string" } },
            "verification_target": { "type": "array", "items": { "type": "string" } },
            "control_gates": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": true
        },
        "strategy_governor": {
          "type": "object",
          "required": ["origin_goal", "strategic_goal", "thread_id", "task_id"],
          "properties": {
            "origin_goal": { "type": "string" },
            "strategic_goal": { "type": "string" },
            "thread_id": { "type": "string" },
            "task_id": { "type": "string" }
          },
          "additionalProperties": true
        },
        "review_close_task": {
          "type": "object",
          "required": ["result_status", "evidence", "gain", "waste", "next_iterate"],
          "properties": {
            "result_status": { "type": "string" },
            "evidence": { "type": "array", "items": { "type": "string" } },
            "gain": { "type": "array", "items": { "type": "string" } },
            "waste": { "type": "array", "items": { "type": "string" } },
            "next_iterate": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "decisionWithBasis": {
      "type": "object",
      "required": ["decision", "basis"],
      "properties": {
        "decision": { "type": "string" },
        "basis": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
