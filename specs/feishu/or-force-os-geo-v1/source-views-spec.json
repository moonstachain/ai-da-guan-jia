    "dimensions": [
      {
        "id": "priority_band",
        "name": "优先级",
        "field": "优先级"
      },
      {
        "id": "collection_state",
        "name": "当前收录状态",
        "field": "当前收录状态"
      }
    ],
    "filters": [
      "所属产品线 = YSE",
      "优先级 = P0 OR 当前收录状态 != 已收录"
