[
  {
    "id": "view-overview-health",
    "view_name": "overview-当前 YSE 试点健康吗",
    "table_id": "ops_snapshots",
    "table_name": "T06_运营快照",
    "question_id": "dq-overview-01",
    "question": "当前 YSE 试点健康吗？",
    "layer": "overview",
    "metrics": [
      {
        "id": "collection_rate_latest",
        "name": "最新收录率",
        "aggregation": "latest"
      },
      {
        "id": "collected_term_count",
        "name": "已收录蒸馏词数",
        "aggregation": "count"
      }
    ],
    "dimensions": [
      {
        "id": "date_key",
        "name": "日期",
        "field": "日期"
      }
    ],
    "filters": [
      "Phase 1 only",
      "recent window = last 14 days"
    ],
    "display_fields": [
      "日期",
      "总蒸馏词",
      "已收录数",
      "收录率",
      "各平台分布"
    ],
    "action_target_ids": [
      "trial_health_queue"
    ]
  },
  {
    "id": "view-overview-focus",
