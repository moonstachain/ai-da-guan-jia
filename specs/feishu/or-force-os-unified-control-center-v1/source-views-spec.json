[
  {
    "id": "view-overview-health",
    "view_name": "overview-当前系统健康吗",
    "table_id": "runtime_control",
    "table_name": "L0_运行态总控",
    "question_id": "dq-overview-01",
    "question": "当前系统健康吗？",
    "layer": "overview",
    "metrics": [
      {
        "id": "health_score",
        "name": "健康度",
        "aggregation": "derived_health_score"
      }
    ],
    "dimensions": [
      {
        "id": "health_domain",
        "name": "健康域",
        "field": "health_domain"
      }
    ],
    "filters": [
      "time grain = day"
    ],
    "display_fields": [
      "health_domain",
      "health_state",
      "risk_level",
      "blocker_count",
      "last_refresh_at"
    ],
    "action_target_ids": [
      "health_queue"
    ]
  },
  {
    "id": "view-overview-focus",
    "view_name": "overview-当前最该盯的聚焦是什么",
    "table_id": "strategic_task_tracking",
    "table_name": "战略任务追踪",
    "question_id": "dq-overview-02",
    "question": "当前最该盯的聚焦是什么？",
    "layer": "overview",
    "metrics": [
      {
        "id": "focus_item_count",
        "name": "聚焦事项数",
        "aggregation": "count"
      }
    ],
    "dimensions": [
      {
        "id": "focus_state",
        "name": "聚焦状态",
        "field": "task_status"
      }
    ],
    "filters": [
      "time grain = day",
      "task_status in [in_progress, waiting_human, blocked_system]"
    ],
    "display_fields": [
      "task_id",
      "task_name",
      "task_status",
      "priority",
      "owner",
      "next_action",
      "evidence_ref"
    ],
    "action_target_ids": [
      "focus_queue"
    ]
  },
  {
    "id": "view-overview-risk",
    "view_name": "overview-当前阻塞与风险是什么",
    "table_id": "clone_risk_decision",
    "table_name": "风险与决策表",
    "question_id": "dq-overview-03",
    "question": "当前阻塞与风险是什么？",
    "layer": "overview",
    "metrics": [
      {
        "id": "blocker_count",
        "name": "阻塞数",
        "aggregation": "count_filtered"
      },
      {
        "id": "risk_count",
        "name": "风险数",
        "aggregation": "count_filtered"
      }
    ],
    "dimensions": [
      {
        "id": "risk_level",
        "name": "风险等级",
        "field": "severity"
      }
    ],
    "filters": [
      "time grain = day",
      "decision_status in [pending_review, escalated] OR severity in [warning, critical]"
    ],
    "display_fields": [
      "clone_id",
      "alert_id",
      "type",
      "severity",
      "message",
      "decision",
      "resolved",
      "timestamp"
    ],
    "action_target_ids": [
      "risk_queue"
    ]
  },
  {
    "id": "view-overview-evolution",
    "view_name": "overview-本周进化了什么",
    "table_id": "evolution_chronicle",
    "table_name": "原力OS进化编年史",
    "question_id": "dq-overview-04",
    "question": "本周进化了什么？",
    "layer": "overview",
    "metrics": [
      {
        "id": "evolution_delta_count",
        "name": "进化增量数",
        "aggregation": "count"
      }
    ],
    "dimensions": [
      {
        "id": "week_key",
        "name": "周键",
        "field": "week_key"
      }
    ],
    "filters": [
      "time grain = week"
    ],
    "display_fields": [
      "week_key",
      "theme",
      "delta_summary",
      "evidence_ref",
      "updated_at"
    ],
    "action_target_ids": [
      "evolution_queue"
    ]
  },
  {
