  {
    "id": "view-action-human-click",
    "view_name": "action-哪些事项需要人类点击",
    "table_id": "strategic_task_tracking",
    "table_name": "战略任务追踪",
    "question_id": "dq-action-01",
    "question": "哪些事项需要人类点击？",
    "layer": "action",
    "metrics": [
      {
        "id": "human_click_count",
        "name": "人类点击数",
        "aggregation": "count_filtered"
      }
    ],
    "dimensions": [
      {
        "id": "human_boundary_state",
        "name": "人类边界状态",
        "field": "human_boundary_state"
      }
    ],
    "filters": [
      "time grain = day",
      "human_boundary_state != done"
    ],
    "display_fields": [
      "task_id",
      "task_name",
      "task_status",
      "human_boundary_state",
      "required_human_action",
      "owner",
      "next_action"
    ],
    "action_target_ids": [
      "human_click_queue"
    ]
  },
  {
    "id": "view-action-approval",
