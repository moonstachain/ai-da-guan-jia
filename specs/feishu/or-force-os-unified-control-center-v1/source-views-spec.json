      }
    ],
    "dimensions": [
      {
        "id": "approval_state",
        "name": "审批状态",
        "field": "status"
      }
    ],
    "filters": [
      "time grain = day",
      "status in [pending_review, deferred]"
    ],
    "display_fields": [
