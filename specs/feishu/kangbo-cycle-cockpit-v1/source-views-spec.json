[
  {
    "id": "view-dq-overview-01",
    "view_name": "overview-当前重点落在哪个康波阶段-风险温度处于什么水平",
    "table_id": "current_signals",
    "table_name": "L1_康波事件信号",
    "question_id": "dq-overview-01",
    "question": "当前重点落在哪个康波阶段，风险温度处于什么水平？",
    "layer": "overview",
    "metrics": [
      {
        "id": "current_signal_count",
        "name": "当前事件数",
        "aggregation": "count"
      },
      {
        "id": "current_severity",
        "name": "当前风险等级",
        "aggregation": "latest"
      }
    ],
    "dimensions": [
      {
        "id": "signal_phase",
        "name": "当前信号阶段",
        "field": "kangbo_phase"
      },
      {
        "id": "signal_category",
        "name": "当前信号类别",
        "field": "event_category"
      }
    ],
    "filters": [
      "最新事件，仅展示 event_name/event_summary/scenario_shift/source_article"
    ],
    "display_fields": [
      "kangbo_phase",
      "event_category",
      "event_name",
      "event_date",
      "severity",
      "event_summary",
      "scenario_shift",
      "source_article"
    ],
    "action_target_ids": [
      "current_signal_detail"
    ]
  },
