{
  "id": "yuanli-os-collaborative-governance-dashboard-v3",
  "title": "原力OS 协同治理总控舱",
  "goal": "为原力OS生成一个单页协同治理控制台，让陌生人先理解系统身份与协同方式，再帮助人类判断当前控制态、阻塞边界、证据线索和下一步动作。",
  "audience": [
    "hay",
    "原力OS 人类协作者",
    "第一次接触原力OS的人类运营者"
  ],
  "product_definition": {
    "external_name": "原力OS",
    "internal_engine": "AI大管家",
    "page_type": "single_page_governance_control_center",
    "language": "zh-CN",
    "positioning": [
      "human_operating_cockpit",
      "governance_control_center",
      "not_generic_bi",
      "not_multi_page_admin",
      "onboarding_first",
      "evidence_first"
    ]
  },
  "source_of_truth": {
    "docs_link": "https://h52xu4gwob.feishu.cn/wiki/BNCQwWVZdiEbIFkpeL6cYuKMnxg?from=from_copylink",
    "base_link": "https://h52xu4gwob.feishu.cn/wiki/Iwzvwon1IiIEo4kQcX5cm0pMnyc?from=from_copylink",
    "whitepaper_bundle": "/Users/hay2045/Documents/codex-ai-gua-jia-01/output/ai-da-guan-jia/control-base/current/whitepaper",
    "review_memo_v1": "/Users/hay2045/Documents/codex-ai-gua-jia-01/docs/yuanli-os-collaborative-governance-dashboard-review-memo-v1.md",
    "review_memo_v2": "/Users/hay2045/Documents/codex-ai-gua-jia-01/docs/yuanli-os-collaborative-governance-dashboard-review-memo-v2.md"
  },
  "benchmark_reference": {
    "project": "openclaw-control-center",
    "repo_url": "https://github.com/TianyiDataScience/openclaw-control-center",
    "borrow": [
      "control_center_posture",
      "real_work_vs_waiting_distinction",
      "evidence_plus_action_colocation",
      "secondary_workbench_entry"
    ],
    "do_not_copy": [
      "openclaw_runtime_coupling",
      "multi_section_admin_homepage",
      "ops_signals_as_first_priority",
      "settings_and_config_as_primary_content"
    ]
  },
  "design_priorities": [
    "control_center_posture",
    "human_clarity_first",
    "intervention_precision",
    "evidence_first",
    "premium_but_quiet_visuals",
    "single_page_cockpit"
  ],
  "onboarding_contract": {
    "placement": "below_hero",
    "format": "three_light_cards_or_three_short_blocks",
    "principles": [
      "shorter_than_whitepaper",
      "more_conversational_than_manual",
      "visible_before_data",
      "not_longform_copy"
    ],
    "modules": [
      {
        "id": "what_is_yuanli_os",
        "title": "原力OS 是什么",
        "must_cover": [
          "原力OS 是 AI大管家 的人类外显层",
          "它是人机协同治理系统",
          "它不是普通聊天助手，也不是普通报表"
        ]
      },
      {
        "id": "how_we_collaborate",
        "title": "你和它怎么协同",
        "must_cover": [
          "你负责目标、边界和不可替代判断",
          "系统负责统筹、推进、验真和闭环",
          "你不需要替系统拆每一步"
        ]
      },
      {
        "id": "how_to_read_this_page",
        "title": "这页该怎么看",
        "must_cover": [
          "先看当前控制态",
          "再看阻塞与原因",
          "然后看该做什么",
          "如果要深入，再进入对应工作台"
        ]
      }
    ]
  },
  "control_center_contract": {
    "hero_must_signal": [
      "runtime_state",
      "frontstage_focus",
      "risk_level",
      "last_refresh_time"
    ],
    "must_distinguish": [
      "actively_progressing",
      "queued_only",
      "blocked_needs_user",
      "blocked_system"
    ],
    "must_expose_evidence": [
      "source_view",
      "related_object",
      "next_action"
    ],
    "workbench_entry_targets": [
      "threads",
      "tasks",
      "decisions",
      "sources",
      "docs_memory"
    ]
  },
  "decision_questions": [
    {
      "id": "dq-kpi-01",
      "layer": "overview",
      "question": "当前真正处于前台推进的主线有几条？",
      "metric_ids": [
        "frontstage_thread_count"
      ],
      "dimension_ids": [
        "operating_segment"
      ]
    },
    {
      "id": "dq-kpi-02",
      "layer": "overview",
      "question": "当前有多少事项只差我输入？",
      "metric_ids": [
        "blocked_needs_user_count"
      ],
      "dimension_ids": [
        "human_boundary_state"
      ],
      "action_target_ids": [
        "needs_user_queue"
      ]
    },
    {
      "id": "dq-kpi-03",
      "layer": "overview",
      "question": "当前有多少系统级阻塞正在挡路？",
      "metric_ids": [
        "blocked_system_count"
      ],
      "dimension_ids": [
        "object_status"
      ],
      "action_target_ids": [
        "blocked_system_queue"
      ]
    },
    {
      "id": "dq-kpi-04",
      "layer": "overview",
      "question": "数据源联通和 transport 当前是否健康？",
      "metric_ids": [
        "source_health_score"
      ],
      "dimension_ids": [
        "source_family"
      ],
      "action_target_ids": [
        "source_sync_queue"
      ]
    },
    {
      "id": "dq-card-01",
      "layer": "diagnosis",
      "question": "当前主会场到底在推什么，哪些是真推进，哪些只是等待？",
      "metric_ids": [
        "frontstage_thread_count"
      ],
      "dimension_ids": [
        "object_status",
        "owner_mode"
      ],
      "action_target_ids": [
        "frontstage_threads_queue"
      ]
    },
    {
      "id": "dq-card-02",
      "layer": "diagnosis",
      "question": "任务整体推进态分布如何，堵点集中在哪？",
      "metric_ids": [
        "task_status_count"
      ],
      "dimension_ids": [
        "task_status"
      ],
      "action_target_ids": [
        "next_action_queue"
      ]
    },
    {
      "id": "dq-card-03",
      "layer": "diagnosis",
      "question": "数据源同步、transport 和 source 覆盖现在健康吗？",
      "metric_ids": [
        "connected_sources_count",
        "missing_sources_count"
      ],
      "dimension_ids": [
        "remote_reachable_flag"
      ],
      "action_target_ids": [
        "source_sync_queue"
      ]
    },
    {
      "id": "dq-card-04",
      "layer": "diagnosis",
      "question": "最近系统做了哪些 review、decision 和 writeback？",
      "metric_ids": [
        "recent_governance_velocity"
      ],
      "dimension_ids": [
        "event_time"
      ],
      "action_target_ids": [
        "decision_trace_queue"
      ]
    },
    {
      "id": "dq-action-01",
      "layer": "action",
      "question": "现在哪些事项必须由我介入？",
      "metric_ids": [
        "blocked_needs_user_count"
      ],
      "action_target_ids": [
        "needs_user_queue"
      ]
    },
    {
      "id": "dq-action-02",
      "layer": "action",
      "question": "哪些系统阻塞需要单独处理，而不是继续假推进？",
      "metric_ids": [
        "blocked_system_count"
      ],
      "action_target_ids": [
        "blocked_system_queue"
      ]
    },
    {
      "id": "dq-action-03",
      "layer": "action",
      "question": "如果现在开始推进，优先动作是什么？",
      "metric_ids": [
        "frontstage_thread_count"
      ],
      "action_target_ids": [
        "next_action_queue"
      ]
    },
    {
      "id": "dq-action-04",
      "layer": "action",
      "question": "哪些能力价值高，但审批或授权摩擦大？",
      "metric_ids": [
        "approval_friction_score"
      ],
      "dimension_ids": [
        "requires_human_approval_flag"
      ],
      "action_target_ids": [
        "capability_friction_queue"
      ]
    }
  ],
