{
  "id": "ibm-cbm-governance-dashboard-v1",
  "title": "IBM CBM 深融后的原力OS总控舱与组件驾驶舱",
  "goal": "把原力OS 从治理总控舱升级成总控舱加组件驾驶舱，让共同治理者同时看见控制态、组件失衡、责任缺口、优先级和行动队列。",
  "audience": [
    "共同治理者",
    "AI大管家",
    "治理运营者",
    "第一次接触原力OS的人类协作者"
  ],
  "decision_questions": [
    {
      "id": "dq-overview-01",
      "layer": "overview",
      "question": "当前系统处于什么控制态？",
      "metric_ids": [
        "runtime_state_count"
      ],
      "dimension_ids": [
        "runtime_state"
      ],
      "chart_preference": "table"
    },
    {
      "id": "dq-overview-02",
      "layer": "overview",
      "question": "当前真正处于前台推进的主线有哪些？",
      "metric_ids": [
        "frontstage_thread_count"
      ],
      "dimension_ids": [
        "operating_segment"
      ],
      "action_target_ids": [
        "frontstage_threads_queue"
      ],
      "chart_preference": "bar_chart"
    },
    {
      "id": "dq-overview-03",
      "layer": "overview",
      "question": "当前有多少事项必须由你介入？",
      "metric_ids": [
        "blocked_needs_user_count"
      ],
      "dimension_ids": [
        "human_boundary_state"
      ],
      "action_target_ids": [
        "needs_user_queue"
      ],
      "chart_preference": "bar_chart"
    },
    {
      "id": "dq-overview-04",
      "layer": "overview",
      "question": "当前有多少系统级阻塞正在挡路？",
      "metric_ids": [
        "blocked_system_count"
      ],
      "dimension_ids": [
        "runtime_state"
      ],
      "action_target_ids": [
        "blocked_system_queue"
      ],
      "chart_preference": "bar_chart"
    },
    {
      "id": "dq-component-01",
      "card_id": "overview-05",
      "layer": "component_matrix",
      "question": "哪些组件当前优先级最高？",
      "metric_ids": [
        "high_priority_component_count"
      ],
      "dimension_ids": [
        "component_domain",
        "priority_band"
      ],
      "action_target_ids": [
        "priority_actions_queue"
      ],
      "chart_preference": "bar_chart"
    },
    {
      "id": "dq-component-02",
      "card_id": "overview-06",
      "layer": "component_matrix",
      "question": "哪些组件在 direct、control、execute 上最失衡？",
      "metric_ids": [
        "component_gap_count"
      ],
      "dimension_ids": [
        "component_domain",
        "control_level"
      ],
      "action_target_ids": [
        "control_imbalance_queue"
      ],
      "chart_preference": "table"
    },
    {
      "id": "dq-component-03",
      "card_id": "overview-07",
      "layer": "component_matrix",
      "question": "哪些组件的人类 Owner 或 AI Copilot 仍然缺位？",
      "metric_ids": [
        "component_owner_gap_count"
      ],
      "dimension_ids": [
        "component_domain",
        "owner_gap_status"
      ],
      "action_target_ids": [
        "component_owner_gap_queue"
      ],
      "chart_preference": "table"
    },
    {
      "id": "dq-component-04",
      "card_id": "overview-08",
      "layer": "component_matrix",
      "question": "哪些组件 gap 最大、最值得优先补？",
      "metric_ids": [
        "hot_component_count"
      ],
      "dimension_ids": [
        "component_domain",
        "priority_band",
        "evidence_strength"
      ],
      "action_target_ids": [
        "component_heatmap_queue"
      ],
      "chart_preference": "table"
    },
    {
      "id": "dq-diagnosis-01",
      "layer": "diagnosis",
      "question": "当前主会场到底在推什么？",
      "metric_ids": [
        "frontstage_thread_count"
      ],
      "dimension_ids": [
        "component_domain"
      ],
      "action_target_ids": [
        "frontstage_threads_queue"
      ],
      "chart_preference": "table"
    },
    {
      "id": "dq-diagnosis-02",
      "layer": "diagnosis",
      "question": "哪些任务是真推进，哪些只是看起来在推进？",
      "metric_ids": [
        "active_task_count"
      ],
      "dimension_ids": [
        "task_status",
        "priority_band"
      ],
      "action_target_ids": [
        "pseudo_progress_queue"
      ],
      "chart_preference": "table"
    },
    {
      "id": "dq-diagnosis-03",
      "card_id": "diagnosis-03",
      "layer": "diagnosis",
      "question": "数据源与证据链当前健康吗？",
      "metric_ids": [
        "source_health_issue_count"
      ],
      "dimension_ids": [
        "source_health_state"
      ],
      "action_target_ids": [
        "source_evidence_queue"
      ],
      "chart_preference": "bar_chart"
    },
    {
      "id": "dq-diagnosis-04",
      "layer": "diagnosis",
      "question": "最近系统做了哪些 review、decision 和 writeback？",
      "metric_ids": [
        "recent_governance_event_count"
      ],
      "dimension_ids": [
        "review_date"
      ],
      "action_target_ids": [
        "governance_trace_queue"
      ],
      "chart_preference": "line_chart"
    },
    {
      "id": "dq-action-01",
      "layer": "action",
      "question": "哪些事项必须由你立即处理？",
      "action_target_ids": [
        "needs_user_queue"
      ],
      "chart_preference": "table"
    },
    {
      "id": "dq-action-02",
      "layer": "action",
      "question": "哪些系统阻塞不能再假推进，必须单独处理？",
      "action_target_ids": [
        "blocked_system_queue"
      ],
      "chart_preference": "table"
    },
    {
      "id": "dq-action-03",
      "layer": "action",
      "question": "如果现在开始推进，优先动作是什么？",
      "metric_ids": [
        "priority_action_count"
      ],
      "dimension_ids": [
        "component_domain",
        "priority_band"
      ],
      "action_target_ids": [
        "priority_actions_queue"
      ],
      "chart_preference": "table"
    },
    {
      "id": "dq-action-04",
      "card_id": "action-04",
      "layer": "action",
      "question": "哪些能力价值高，但审批或授权摩擦仍然很大？",
      "metric_ids": [
        "approval_friction_count"
      ],
      "dimension_ids": [
        "capability_cluster"
      ],
      "action_target_ids": [
        "approval_friction_queue"
      ],
      "chart_preference": "table"
    }
  ],
  "tables": [
    {
      "id": "control_objects",
      "name": "总控对象主表",
      "grain": "control_object",
      "fields": [
        "对象Key",
        "对象类型",
        "对象标题",
        "治理层级",
        "运营分段",
        "对象状态",
        "goal_id",
        "component_domain",
        "control_level",
        "priority_band",
        "owner_mode",
        "human_boundary_state",
        "需要人类输入",
        "阻塞原因",
        "下一步动作",
        "evidence_ref",
        "evidence_strength",
        "updated_at"
      ]
    },
    {
      "id": "strategic_linkage",
      "name": "战略链路表",
      "grain": "strategic_link",
      "fields": [
        "战略链路Key",
        "goal_id",
        "theme_id",
        "strategy_id",
        "experiment_id",
        "workflow_id",
        "component_domain",
        "control_level_scope",
        "status",
        "current_gap",
        "next_action",
        "evidence_ref",
        "updated_at"
      ]
    },
    {
      "id": "cbm_component_responsibility",
      "name": "CBM组件责任表",
      "grain": "component_domain",
      "fields": [
        "组件Key",
        "component_domain",
        "control_level_scope",
        "human_owner",
        "ai_copilot",
        "goal_id",
        "theme_id",
        "strategy_id",
        "workflow_id",
        "owner_gap",
        "status",
        "evidence_ref",
        "updated_at"
      ]
    },
    {
      "id": "cbm_component_heatmap",
      "name": "CBM组件热图表",
      "grain": "component_domain_control_level",
      "fields": [
        "热图Key",
        "component_domain",
        "control_level",
        "kpi_hint",
        "current_gap",
        "priority_band",
        "next_action",
        "owner_mode",
        "evidence_strength",
        "latest_decision_id",
        "latest_writeback_id",
        "status",
        "updated_at"
      ]
    },
    {
      "id": "threads",
      "name": "线程总表",
      "grain": "thread",
      "fields": [
        "thread_id",
        "title",
        "goal_id",
        "theme_id",
        "strategy_id",
        "experiment_id",
        "workflow_id",
        "component_domain",
        "control_level",
        "status",
        "required_human_input",
        "blocker_reason",
        "updated_at"
      ]
    },
    {
      "id": "tasks",
      "name": "任务总表",
      "grain": "task",
      "fields": [
        "task_id",
        "title",
        "thread_id",
        "goal_id",
        "component_domain",
        "control_level",
        "owner_mode",
        "human_boundary_state",
        "task_status",
        "kpi_gap",
        "priority_band",
        "next_action",
        "evidence_ref",
        "updated_at"
      ]
    },
    {
      "id": "skills_capabilities",
      "name": "技能与能力表",
      "grain": "skill_or_capability",
      "fields": [
        "capability_key",
        "record_type",
        "name",
        "cluster_or_actor",
        "routing_credit",
        "verification_strength",
        "requires_human_approval",
        "status",
        "updated_at"
      ]
    },
    {
      "id": "source_feeds",
      "name": "数据源同步表",
      "grain": "source_feed",
      "fields": [
        "source_feed_id",
        "title",
        "source_family",
        "status",
        "remote_reachable",
        "missing_sources_snapshot",
        "connected_sources_snapshot",
        "updated_at"
      ]
    },
    {
      "id": "review_runs",
      "name": "Review批次表",
      "grain": "review_run",
      "fields": [
        "review_id",
        "review_date",
        "scope",
        "summary",
        "top_risks",
        "candidate_actions",
        "human_decision",
        "updated_at"
      ]
    },
    {
      "id": "decision_records",
      "name": "决策记录表",
      "grain": "decision_record",
      "fields": [
        "decision_id",
        "title",
        "decision_type",
        "decision_state",
        "target_entity_ids",
        "decision_summary",
        "rationale",
        "evidence_refs",
        "decision_time",
        "updated_at"
      ]
    },
    {
      "id": "governance_events",
      "name": "治理动作与写回表",
      "grain": "governance_event",
      "fields": [
        "governance_event_key",
        "record_type",
        "title",
        "status",
        "target_entity_type_or_refs",
        "required_policy_ids",
        "verification_state",
        "evidence_refs",
        "event_time",
        "updated_at"
      ]
    }
  ],
  "metrics": [
    {
      "id": "runtime_state_count",
      "name": "控制态分布",
      "table_id": "control_objects",
      "aggregation": "count",
      "field": "对象状态"
    },
    {
      "id": "frontstage_thread_count",
      "name": "前台主线数",
      "table_id": "threads",
      "aggregation": "count"
    },
    {
      "id": "blocked_needs_user_count",
      "name": "待你处理数",
      "table_id": "control_objects",
      "aggregation": "count"
    },
    {
      "id": "blocked_system_count",
      "name": "系统阻塞数",
      "table_id": "control_objects",
      "aggregation": "count"
    },
    {
      "id": "high_priority_component_count",
      "name": "高优先级组件数",
      "table_id": "cbm_component_heatmap",
      "aggregation": "count",
      "field": "priority_band"
    },
    {
      "id": "component_gap_count",
      "name": "组件缺口数",
      "table_id": "cbm_component_heatmap",
      "aggregation": "count"
    },
    {
      "id": "component_owner_gap_count",
      "name": "组件责任缺口数",
      "table_id": "cbm_component_responsibility",
      "aggregation": "count",
      "field": "owner_gap"
    },
    {
      "id": "hot_component_count",
      "name": "热点组件数",
      "table_id": "cbm_component_heatmap",
      "aggregation": "count",
      "field": "component_domain"
    },
    {
      "id": "active_task_count",
      "name": "活跃任务数",
      "table_id": "tasks",
      "aggregation": "count"
    },
    {
      "id": "source_health_issue_count",
      "name": "数据源健康异常数",
      "table_id": "source_feeds",
      "aggregation": "count"
    },
    {
      "id": "recent_governance_event_count",
      "name": "近期治理动作数",
      "table_id": "governance_events",
      "aggregation": "count"
    },
    {
      "id": "priority_action_count",
      "name": "优先动作数",
      "table_id": "cbm_component_heatmap",
      "aggregation": "count",
      "field": "priority_band"
    },
    {
      "id": "approval_friction_count",
      "name": "审批摩擦数",
      "table_id": "skills_capabilities",
      "aggregation": "count",
      "field": "requires_human_approval"
    }
  ],
  "dimensions": [
    {
      "id": "runtime_state",
      "name": "控制态",
      "table_id": "control_objects",
      "field": "对象状态",
      "type": "single_select"
    },
    {
      "id": "operating_segment",
      "name": "运营分段",
      "table_id": "control_objects",
      "field": "运营分段",
      "type": "single_select"
    },
    {
      "id": "human_boundary_state",
      "name": "人类边界状态",
      "table_id": "control_objects",
      "field": "human_boundary_state",
      "type": "single_select"
    },
    {
      "id": "component_domain",
      "name": "组件域",
      "table_id": "cbm_component_heatmap",
      "field": "component_domain",
      "type": "single_select"
    },
    {
      "id": "control_level",
      "name": "管理纵线",
      "table_id": "cbm_component_heatmap",
      "field": "control_level",
      "type": "single_select"
    },
    {
      "id": "priority_band",
      "name": "优先级带",
      "table_id": "cbm_component_heatmap",
      "field": "priority_band",
      "type": "single_select"
    },
    {
      "id": "owner_gap_status",
      "name": "责任缺口状态",
      "table_id": "cbm_component_responsibility",
      "field": "owner_gap",
      "type": "single_select"
    },
    {
      "id": "evidence_strength",
      "name": "证据强度",
      "table_id": "cbm_component_heatmap",
      "field": "evidence_strength",
      "type": "single_select"
    },
    {
      "id": "task_status",
      "name": "任务状态",
      "table_id": "tasks",
      "field": "task_status",
      "type": "single_select"
    },
    {
      "id": "source_health_state",
      "name": "数据源健康",
      "table_id": "source_feeds",
      "field": "status",
      "type": "single_select"
    },
    {
      "id": "review_date",
      "name": "评审日期",
      "table_id": "review_runs",
      "field": "review_date",
      "type": "time"
    },
    {
      "id": "capability_cluster",
      "name": "能力簇",
      "table_id": "skills_capabilities",
      "field": "cluster_or_actor",
      "type": "single_select"
    }
  ],
  "time_grain": "day",
  "action_targets": [
    {
      "id": "needs_user_queue",
      "name": "待你处理队列",
      "table_id": "control_objects",
      "record_filter": "需要人类输入 != 空",
      "display_fields": [
        "对象标题",
        "component_domain",
        "control_level",
        "需要人类输入",
        "阻塞原因",
        "下一步动作",
        "evidence_ref"
      ]
    },
    {
      "id": "blocked_system_queue",
      "name": "系统阻塞队列",
      "table_id": "control_objects",
      "record_filter": "对象状态 = blocked_system",
      "display_fields": [
        "对象标题",
        "component_domain",
        "control_level",
        "阻塞原因",
        "下一步动作",
        "evidence_ref"
      ]
    },
    {
      "id": "frontstage_threads_queue",
      "name": "前台主线队列",
      "table_id": "threads",
      "record_filter": "status in [active, frontstage_now]",
      "display_fields": [
        "title",
        "goal_id",
        "component_domain",
        "control_level",
        "status",
        "required_human_input",
        "blocker_reason"
      ]
    },
    {
      "id": "component_owner_gap_queue",
      "name": "组件 Owner Gap 队列",
      "table_id": "cbm_component_responsibility",
      "record_filter": "owner_gap != none",
      "display_fields": [
        "component_domain",
        "control_level_scope",
        "human_owner",
        "ai_copilot",
        "owner_gap",
        "goal_id",
        "strategy_id",
        "evidence_ref"
      ]
    },
    {
      "id": "component_heatmap_queue",
      "name": "组件热图优先队列",
      "table_id": "cbm_component_heatmap",
      "record_filter": "priority_band in [P0, P1]",
      "display_fields": [
        "component_domain",
        "control_level",
        "kpi_hint",
        "current_gap",
        "priority_band",
        "next_action",
        "evidence_strength"
      ]
    },
    {
      "id": "control_imbalance_queue",
      "name": "管理纵线失衡队列",
      "table_id": "cbm_component_heatmap",
      "record_filter": "current_gap != 空",
      "display_fields": [
        "component_domain",
        "control_level",
        "current_gap",
        "priority_band",
        "next_action",
        "latest_decision_id"
      ]
    },
    {
      "id": "pseudo_progress_queue",
      "name": "假推进排查队列",
      "table_id": "tasks",
      "record_filter": "task_status in [waiting, blocked_needs_user, blocked_system]",
      "display_fields": [
        "title",
        "thread_id",
        "component_domain",
        "control_level",
        "task_status",
        "priority_band",
        "next_action",
        "evidence_ref"
      ]
    },
    {
      "id": "source_evidence_queue",
      "name": "数据源与证据健康队列",
      "table_id": "source_feeds",
      "record_filter": "status != healthy OR missing_sources_snapshot != none",
      "display_fields": [
        "title",
        "source_family",
        "status",
        "remote_reachable",
        "missing_sources_snapshot",
        "connected_sources_snapshot"
      ]
    },
    {
      "id": "governance_trace_queue",
      "name": "治理轨迹队列",
      "table_id": "governance_events",
      "record_filter": "event_time within last 14 days",
      "display_fields": [
        "title",
        "record_type",
        "status",
        "verification_state",
        "evidence_refs",
        "event_time"
      ]
    },
    {
      "id": "priority_actions_queue",
      "name": "优先动作队列",
      "table_id": "cbm_component_heatmap",
      "record_filter": "priority_band in [P0, P1] AND next_action != 空",
      "display_fields": [
        "component_domain",
        "control_level",
        "priority_band",
        "current_gap",
        "next_action",
        "latest_decision_id",
        "latest_writeback_id"
      ]
    },
    {
      "id": "approval_friction_queue",
      "name": "审批摩擦队列",
      "table_id": "skills_capabilities",
      "record_filter": "requires_human_approval = 是",
      "display_fields": [
        "name",
        "cluster_or_actor",
        "routing_credit",
        "verification_strength",
        "requires_human_approval",
        "status"
      ]
    }
  ]
}
