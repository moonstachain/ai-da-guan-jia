{
  "id": "yuanli-os-collaborative-governance-dashboard-v2",
  "title": "原力OS 协同治理总控舱",
  "goal": "为原力OS生成一个对陌生人也友好的单页协同治理驾驶舱，先帮助用户理解系统身份和使用方式，再展示运行态、阻塞与下一步动作。",
  "audience": [
    "hay",
    "原力OS 人类协作者",
    "第一次接触原力OS的人类运营者"
  ],
  "product_definition": {
    "external_name": "原力OS",
    "internal_engine": "AI大管家",
    "page_type": "single_page_governance_cockpit",
    "language": "zh-CN",
    "positioning": [
      "human_operating_cockpit",
      "governance_dashboard",
      "not_generic_bi",
      "not_kondratieff_timeline_clone",
      "onboarding_first"
    ]
  },
  "source_of_truth": {
    "docs_link": "https://h52xu4gwob.feishu.cn/wiki/BNCQwWVZdiEbIFkpeL6cYuKMnxg?from=from_copylink",
    "base_link": "https://h52xu4gwob.feishu.cn/wiki/Iwzvwon1IiIEo4kQcX5cm0pMnyc?from=from_copylink",
    "whitepaper_bundle": "/Users/hay2045/Documents/codex-ai-gua-jia-01/output/ai-da-guan-jia/control-base/current/whitepaper",
    "review_memo": "/Users/hay2045/Documents/codex-ai-gua-jia-01/docs/yuanli-os-collaborative-governance-dashboard-review-memo-v1.md"
  },
  "design_priorities": [
    "human_clarity_first",
    "premium_but_quiet_visuals",
    "single_page_cockpit",
    "no_extra_card_bloat"
  ],
  "onboarding_contract": {
    "placement": "below_hero",
    "format": "three_light_cards_or_three_short_blocks",
    "principles": [
      "shorter_than_whitepaper",
      "more_conversational_than_manual",
      "visible_before_data",
      "not_longform_copy"
    ],
    "modules": [
      {
        "id": "what_is_yuanli_os",
        "title": "原力OS 是什么",
        "must_cover": [
          "原力OS 是 AI大管家 的人类外显层",
          "它是人机协同治理系统",
          "它不是普通聊天助手，也不是普通报表"
        ]
      },
      {
        "id": "how_we_collaborate",
        "title": "你和它怎么协同",
        "must_cover": [
          "你负责目标、边界和不可替代判断",
          "系统负责统筹、推进、验真和闭环",
          "你不需要替系统拆每一步"
        ]
      },
      {
        "id": "how_to_read_this_page",
        "title": "这页该怎么看",
        "must_cover": [
          "先看运行态",
          "再看阻塞与原因",
          "最后看待你处理和下一步动作"
        ]
      }
    ]
  },
  "decision_questions": [
    {
      "id": "dq-onboarding-01",
      "layer": "orientation",
      "question": "第一次看到这页的人，能否立刻理解原力OS是什么？",
      "answer_card": "onboarding_what_is_yuanli_os"
    },
    {
      "id": "dq-onboarding-02",
      "layer": "orientation",
      "question": "第一次看到这页的人，能否理解自己和系统的分工？",
      "answer_card": "onboarding_collaboration_model"
    },
    {
      "id": "dq-onboarding-03",
      "layer": "orientation",
      "question": "第一次看到这页的人，能否知道阅读顺序和使用方式？",
      "answer_card": "onboarding_reading_guide"
    },
    {
      "id": "dq-kpi-01",
      "layer": "overview",
      "question": "当前真正处于前台推进的主线有几条？",
      "answer_card": "kpi_frontstage_threads"
    },
    {
      "id": "dq-kpi-02",
      "layer": "overview",
      "question": "当前有多少事项只差我输入？",
      "answer_card": "kpi_blocked_needs_user"
    },
    {
      "id": "dq-kpi-03",
      "layer": "overview",
      "question": "当前有多少系统级阻塞正在挡路？",
      "answer_card": "kpi_blocked_system"
    },
    {
      "id": "dq-kpi-04",
      "layer": "overview",
      "question": "数据源联通和 transport 当前是否健康？",
      "answer_card": "kpi_source_health"
    },
    {
      "id": "dq-card-01",
      "layer": "diagnosis",
      "question": "当前主会场到底在推什么？",
      "answer_card": "frontstage_threads"
    },
    {
      "id": "dq-card-02",
      "layer": "diagnosis",
      "question": "任务整体推进态分布如何，堵点集中在哪？",
      "answer_card": "task_status_distribution"
    },
    {
      "id": "dq-card-03",
      "layer": "diagnosis",
      "question": "数据源同步、transport 和 source 覆盖现在健康吗？",
      "answer_card": "source_sync_health"
    },
    {
      "id": "dq-card-04",
      "layer": "diagnosis",
      "question": "最近系统做了哪些 review、decision 和 writeback？",
      "answer_card": "recent_governance_progress"
    },
    {
      "id": "dq-action-01",
      "layer": "action",
      "question": "现在哪些事项必须由我介入？",
      "answer_card": "needs_user_queue"
    },
    {
      "id": "dq-action-02",
      "layer": "action",
      "question": "哪些系统阻塞需要单独处理而不是继续假推进？",
      "answer_card": "blocked_system_queue"
    },
    {
      "id": "dq-action-03",
      "layer": "action",
      "question": "如果现在开始推进，优先动作是什么？",
      "answer_card": "next_action_queue"
    },
    {
      "id": "dq-action-04",
      "layer": "action",
      "question": "哪些能力价值高，但审批或授权摩擦大？",
      "answer_card": "capability_friction"
    }
  ],
  "visual_contract": {
    "reference": "300年康波周期分析仪表盘",
    "translation_rule": "keep_premium_clarity_but_shift_from_historical_narrative_to_quiet_governance_cockpit",
    "theme": {
      "background": "slate_ink_dark",
      "surface": "glass_dark_soft",
      "accent_running": "cyan_blue",
      "accent_needs_user": "amber",
      "accent_blocked_system": "rose_red"
    },
    "style_keywords": [
      "premium",
      "quiet luxury",
      "restrained glassmorphism",
      "clear hierarchy",
      "system product feel",
      "center-of-gravity visual"
    ],
    "avoid": [
      "generic enterprise BI",
      "light spreadsheet aesthetics",
      "historical timeline storytelling",
      "overdecorated sci-fi wall",
      "long manifesto copy"
    ]
  },
  "page_contract": {
    "shape": "single_page",
    "reading_order": [
      "what_is_this",
      "what_is_happening",
      "why_is_it_happening",
      "what_should_i_do"
    ],
