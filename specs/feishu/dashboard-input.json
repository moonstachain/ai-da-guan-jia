      "id": "space_role",
      "name": "联邦角色",
      "table_id": "spaces",
      "field": "联邦角色",
      "type": "single_select"
    },
    {
      "id": "subject_type",
      "name": "主体类型",
      "table_id": "subjects",
      "field": "主体类型",
      "type": "single_select"
    },
    {
      "id": "account_platform",
      "name": "平台",
      "table_id": "accounts",
      "field": "平台",
      "type": "single_select"
