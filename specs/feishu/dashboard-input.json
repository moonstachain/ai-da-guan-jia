{
  "goal": "原力全体系治理系统总览",
  "audience": [
    "治理负责人",
    "人类协作者"
  ],
  "decision_questions": [
    {
      "id": "dq-001",
      "layer": "federation",
      "question": "联邦体系里现在有哪些主体与实例边界？",
      "metric_ids": [
        "space_count",
        "subject_count"
      ],
      "dimension_ids": [
        "space_role",
        "subject_type"
      ],
      "chart_preference": "table"
    },
    {
      "id": "dq-002",
      "layer": "federation",
      "question": "终端与账号阵地覆盖到什么程度，哪里失管？",
      "metric_ids": [
        "account_count"
      ],
      "dimension_ids": [
        "account_platform",
        "account_status"
      ],
      "action_target_ids": [
        "account_risk_queue"
      ],
      "chart_preference": "bar_chart"
    },
    {
      "id": "dq-003",
      "layer": "federation",
      "question": "CBM 模块的人类 Owner 与 AI Copilot 是否齐备？",
      "metric_ids": [
        "module_count"
      ],
      "dimension_ids": [
        "module_status"
      ],
      "action_target_ids": [
        "module_owner_gap_queue"
      ],
      "chart_preference": "table"
    },
    {
      "id": "dq-004",
      "layer": "federation",
      "question": "AI 编制是否形成 Agent + Skill 双层挂接？",
      "metric_ids": [
        "ai_agent_count",
        "skill_count"
      ],
      "dimension_ids": [
        "subject_type",
        "skill_cluster"
      ],
      "action_target_ids": [
        "agent_skill_queue"
      ],
      "chart_preference": "bar_chart"
    },
    {
      "id": "dq-005",
      "layer": "operations",
      "question": "当前最重要的活跃线程是什么？",
      "metric_ids": [
        "active_thread_count"
      ],
      "dimension_ids": [
        "thread_goal"
      ],
      "chart_preference": "table"
    },
    {
      "id": "dq-006",
      "layer": "operations",
      "question": "哪些任务在推进，堵点在哪里？",
      "metric_ids": [
        "task_count"
      ],
      "dimension_ids": [
        "task_status"
      ],
      "action_target_ids": [
        "pending_task_queue"
      ],
      "chart_preference": "bar_chart"
    },
    {
      "id": "dq-007",
      "layer": "operations",
      "question": "哪些技能在高频使用，哪里存在能力缺口？",
      "metric_ids": [
        "skill_count"
      ],
      "dimension_ids": [
        "skill_cluster"
      ],
      "action_target_ids": [
        "skill_gap_queue"
      ],
      "chart_preference": "bar_chart"
    },
    {
      "id": "dq-008",
      "layer": "operations",
      "question": "客户复制实例推进到哪一层了？",
      "metric_ids": [
        "client_space_count"
      ],
      "dimension_ids": [
        "space_role"
      ],
      "action_target_ids": [
        "client_rollout_queue"
      ],
      "chart_preference": "table"
    },
    {
      "id": "dq-009",
      "layer": "action",
      "question": "原力治理系统正在往哪个战略目标进化？",
      "metric_ids": [
        "review_count"
      ],
      "dimension_ids": [
        "review_date"
      ],
      "chart_preference": "line_chart"
    },
    {
      "id": "dq-010",
      "layer": "action",
      "question": "今天早上 9 点要过什么，三种动作候选是什么？",
      "action_target_ids": [
        "today_review_queue"
      ],
      "chart_preference": "table"
    }
  ],
