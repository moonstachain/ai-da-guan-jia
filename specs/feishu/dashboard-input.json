    {
      "id": "subject_count",
      "name": "主体数",
      "table_id": "subjects",
      "aggregation": "count"
    },
    {
      "id": "ai_agent_count",
      "name": "AI Agent 数",
      "table_id": "subjects",
      "aggregation": "count"
    },
    {
      "id": "account_count",
      "name": "账号数",
